<% layout("/layouts/boilerplate") %>

<style>
  /* ── Star input ── */
  .star-rating {
    display: flex;
    flex-direction: row-reverse;
    justify-content: flex-end;
    gap: 2px;
  }
  .star-rating input { display: none; }
  .star-rating label {
    font-size: 2rem;
    color: #ccc;
    cursor: pointer;
    transition: color 0.15s;
  }
  .star-rating label:hover,
  .star-rating label:hover ~ label,
  .star-rating input:checked ~ label {
    color: #f5a623;
  }

  /* ── Star display on cards ── */
  .review-stars { color: #f5a623; font-size: 1.1rem; letter-spacing: 2px; }
  .review-stars .empty { color: #ccc; }
</style>

<div class="col-8 offset-2">
    <h3><%= listing.title %></h3>
</div>

<div class="card col-6 offset-3 show-card listing-card">
    <img 
        src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1625505826533-5c80aca7d157?w=1200' %>" 
        alt="listing image">
    <div class="card-body">
        <p><b>Owner:</b> <i><%= listing.owner ? listing.owner.username : "Unknown Owner" %></i></p>
        <p><%= listing.description %></p>
        <p><b>Price:</b> &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : 'N/A' %></p>
        <p><b>Location:</b> <%= listing.location %></p>
        <p><b>Country:</b> <%= listing.country %></p>
    </div>
</div>

<br>

<% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
<div class="btns">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">
        Edit
    </a>
    <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-dark offset-3">Delete</button>
    </form>
</div>
<% } %>

<div class="col-8 offset-2 mb-3">
    <hr>
    <% if (currUser) { %>
    <h4>Leave a Review</h4>
    <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">
        
        <!-- ★ Star Rating Input -->
        <div class="mb-3 mt-3">
            <label class="form-label d-block">Rating</label>
            <div class="star-rating">
                <input type="radio" id="star5" name="review[rating]" value="5" required />
                <label for="star5" title="5 stars">&#9733;</label>
                <input type="radio" id="star4" name="review[rating]" value="4" />
                <label for="star4" title="4 stars">&#9733;</label>
                <input type="radio" id="star3" name="review[rating]" value="3" />
                <label for="star3" title="3 stars">&#9733;</label>
                <input type="radio" id="star2" name="review[rating]" value="2" />
                <label for="star2" title="2 stars">&#9733;</label>
                <input type="radio" id="star1" name="review[rating]" value="1" />
                <label for="star1" title="1 star">&#9733;</label>
            </div>
            <div class="invalid-feedback d-block" id="rating-error" style="display:none!important">
                Please select a rating.
            </div>
        </div>

        <div class="mb-3 mt-3">
            <label for="comment" class="form-label">Comments</label>
            <textarea 
                name="review[comment]" 
                id="comment" 
                cols="30" 
                rows="5" 
                class="form-control" 
                required></textarea>
            <div class="invalid-feedback">Please submit some comments for the review</div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
    </form>
    <% } %>

    <hr>
    <p><b>All Reviews</b></p>
    <div class="row">
        <% for (let review of listing.reviews) { %>
        <div class="card col-5 ms-3 mb-3">
            <div class="card-body">
                <h5 class="card-title"><%= review.author ? review.author.username : "Anonymous" %></h5>
                <!-- ★ Star display -->
                <p class="card-text review-stars">
                    <% for (let i = 1; i <= 5; i++) { %>
                        <% if (i <= review.rating) { %>
                            <span>&#9733;</span>
                        <% } else { %>
                            <span class="empty">&#9733;</span>
                        <% } %>
                    <% } %>
                </p>
                <p class="card-text"><%= review.comment %></p>
            </div>
            <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
            <form class="mb-3" method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-sm btn-dark">Delete</button>
            </form>
            <% } %>
        </div>
        <% } %>
    </div>
</div>

<!-- Validate star selection on submit -->
<script>
  document.querySelector("form.needs-validation").addEventListener("submit", function (e) {
    const rated = document.querySelector('input[name="review[rating]"]:checked');
    const err = document.getElementById("rating-error");
    if (!rated) {
      e.preventDefault();
      e.stopPropagation();
      err.style.setProperty("display", "block", "important");
    } else {
      err.style.setProperty("display", "none", "important");
    }
    this.classList.add("was-validated");
  });
</script>
